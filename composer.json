{
    "name": "maksde/support",
    "version": "3.0.0",
    "description": "Помощник для Laravel",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "files": [
            "src/functions.php"
        ],
        "psr-4": {
            "Maksde\\Support\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Demyanenko Maksim",
            "email": "demyanenkomaks0@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Maksde\\Support\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.0",
        "laravel/pint": "^1.13",
        "larastan/larastan": "^3.3",
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^10.0"
    },
    "scripts": {
        "test": "./vendor/bin/phpunit",
        "test:coverage": "./vendor/bin/phpunit --coverage-html coverage",
        "pint": "./vendor/bin/pint",
        "phpstan": "./vendor/bin/phpstan analyse --memory-limit=-1",
        "rector": "./vendor/bin/rector process --clear-cache",
        "rector:dry": "./vendor/bin/rector process --clear-cache --dry-run",
        "fix": [
            "@rector",
            "@pint",
            "@phpstan"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maksde\\Support\\SupportServiceProvider"
            ]
        }
    }
}
